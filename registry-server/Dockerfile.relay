FROM eclipse-temurin:21-jre-alpine

WORKDIR /app
COPY p2p-relay/build/libs/p2p-relay.jar /app/
COPY p2p-core/build/libs/p2p-core.jar /app/
COPY p2p-network/build/libs/p2p-network.jar /app/
COPY p2p-crypto/build/libs/p2p-crypto.jar /app/

EXPOSE 9878

ENTRYPOINT ["java", "-cp", "/app/*", "com.p2p.relay.RelayServer"]
CMD ["9878"]
